{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2020",
    "outDir": "./out",
    "lib": ["ES2020"],
    "sourceMap": true,
    "rootDir": "./src",
    "strict": true,
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "types": ["node", "vscode"]
  },
  "exclude": ["node_modules", ".vscode-test", "vscode-color-animator"]
}
